              "type": "object",
              "properties": {
                "description": {"type": "string"},
                "owner": {"type": "string"},
                "severity": {"type": "string", "enum": ["low", "medium", "high"]}
              },
              "required": ["description", "owner", "severity"]
            }
          }
        },
        "required": ["date", "attendees", "deliverable", "due_date", "risks"]
      }
    }
  }

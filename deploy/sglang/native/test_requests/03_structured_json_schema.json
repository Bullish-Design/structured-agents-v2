{
  "model": "base",
  "temperature": 0,
  "max_tokens": 400,
  "messages": [
    {
      "role": "system",
      "content": "Extract structured data from the user's text. Respond only with JSON matching the schema."
    },
    {
      "role": "user",
      "content": "Meeting notes: On March 3rd, Priya Nair (Engineering Lead) and Tom Baker (Product Manager) agreed to ship the v2 billing API by April 18th. Risk: the sandbox environment is unstable, owner is Priya, severity is high. A second, lower risk (medium severity) is that Stripe webhook retries aren't idempotent yet, owned by Tom."
    }
  ],
  "response_format": {
    "type": "json_schema",
